{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interactive Mind Map Data Schema",
  "description": "Schema for interactive exploration mind maps with flashlight discovery and expandable leaves",
  "type": "object",
  "required": ["title", "center", "categories"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the document being visualized"
    },
    "center": {
      "type": "object",
      "description": "Central node of the mind map",
      "required": ["label", "description", "leaves"],
      "properties": {
        "label": {
          "type": "string",
          "description": "Short label for center node (can include \\n for line breaks)"
        },
        "description": {
          "type": "string",
          "description": "Detailed description shown on hover"
        },
        "leaves": {
          "type": "array",
          "description": "Key points that expand from center when clicked",
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": {
                "type": "string",
                "description": "Short title shown on leaf"
              },
              "description": {
                "type": "string",
                "description": "Detailed explanation shown on hover"
              }
            }
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "description": "Categories of nodes radiating from center",
      "items": {
        "type": "object",
        "required": ["type", "label", "color", "nodes"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Category type (timeline, causes, consequences, solutions, or custom)"
          },
          "label": {
            "type": "string",
            "description": "Display label for this category"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$",
            "description": "Hex color code for nodes in this category"
          },
          "nodes": {
            "type": "array",
            "description": "Nodes within this category",
            "items": {
              "type": "object",
              "required": ["label", "description", "position", "size"],
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Node label (can include \\n for line breaks)"
                },
                "description": {
                  "type": "string",
                  "description": "Detailed description shown on hover"
                },
                "position": {
                  "type": "object",
                  "required": ["relativeX", "relativeY"],
                  "properties": {
                    "relativeX": {
                      "type": "number",
                      "description": "X offset from center in pixels"
                    },
                    "relativeY": {
                      "type": "number",
                      "description": "Y offset from center in pixels (negative = up)"
                    }
                  }
                },
                "size": {
                  "type": "number",
                  "description": "Node radius in pixels (typically 50-70)"
                },
                "leaves": {
                  "type": "array",
                  "description": "Detail points that expand when node is clicked",
                  "items": {
                    "type": "object",
                    "required": ["title", "description"],
                    "properties": {
                      "title": {
                        "type": "string",
                        "description": "Short title shown on leaf"
                      },
                      "description": {
                        "type": "string",
                        "description": "Detailed explanation shown on hover"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
